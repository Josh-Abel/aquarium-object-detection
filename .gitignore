# Local environments
.env
.venv/
venv/

# Local datasets. Keep only the documentation/placeholder files in git.
data/*
!data/README.md
!data/.gitkeep

# Local model artifacts. Store large weights outside git or in GitHub Releases.
models/*
!models/README.md
!models/.gitkeep

# Generated training/evaluation outputs.
outputs/*
!outputs/README.md
!outputs/.gitkeep

runs/
tensorboard_logs/
wandb/

